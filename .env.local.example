# Copy to .env.local and fill in the values.

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Lemon Squeezy (subscriptions) -----
# Get the API key from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
# Numeric store ID (visible in URL of your store dashboard)
LEMONSQUEEZY_STORE_ID=
# Numeric variant IDs of the PRO and BUSINESS subscription products
LEMONSQUEEZY_VARIANT_ID_PRO=
LEMONSQUEEZY_VARIANT_ID_BUSINESS=
# Webhook signing secret (set this when creating the webhook in LS dashboard)
LEMONSQUEEZY_WEBHOOK_SECRET=

# ----- App -----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Sentry (error monitoring) -----
# Public DSN for client-side error reporting (safe to expose).
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (same value as NEXT_PUBLIC_SENTRY_DSN unless you split projects).
SENTRY_DSN=
# Build-time auth token used by withSentryConfig to upload source maps.
# Create at https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
# (scope: project:write). Optional locally; required on Vercel for source maps.
SENTRY_AUTH_TOKEN=
